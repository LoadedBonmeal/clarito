{
  "name": "efactura-desktop",
  "private": true,
  "version": "0.7.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:mac": "tauri build --target universal-apple-darwin",
    "build:mac-arm": "tauri build --target aarch64-apple-darwin",
    "build:mac-intel": "tauri build --target x86_64-apple-darwin",
    "build:win-x64": "tauri build --target x86_64-pc-windows-msvc",
    "build:win-nsis": "tauri build --target x86_64-pc-windows-msvc --bundles nsis",
    "build:win-arm": "tauri build --target aarch64-pc-windows-msvc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@embedpdf/core": "2.14.4",
    "@embedpdf/engines": "2.14.4",
    "@embedpdf/pdfium": "2.14.4",
    "@embedpdf/plugin-document-manager": "2.14.4",
    "@embedpdf/plugin-render": "2.14.4",
    "@embedpdf/plugin-rotate": "2.14.4",
    "@embedpdf/plugin-scroll": "2.14.4",
    "@embedpdf/plugin-search": "2.14.4",
    "@embedpdf/plugin-thumbnail": "2.14.4",
    "@embedpdf/plugin-viewport": "2.14.4",
    "@embedpdf/plugin-zoom": "2.14.4",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.170.4",
