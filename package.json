    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.7",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.7"
