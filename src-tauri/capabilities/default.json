{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability principală pentru fereastra main",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" }
      ]
    },
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "os:default",
    "process:allow-exit",
    "notification:default",
    "clipboard-manager:default",
    "store:default",
    "window-state:default",
    "log:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
