{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clarito",
  "version": "0.7.0",
  "identifier": "com.lucaris.efactura",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clarito",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost https://webservicesp.anaf.ro https://api.anaf.ro; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCNjUyNzJDMkRBMEM2NzkKUldSNXhxQXRMQ2RsUzZaQWxYNk5rWW0vQXhyUE1KYlFaR292TExPR1FrTXRFMWdHeUZHU0FvK1oK",
      "endpoints": [
        "https://releases.lucaris.ro/efactura/{{target}}/{{arch}}/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "resources": ["resources/jre-min/**/*", "resources/duk/**/*"],
    "licenseFile": "resources/license.rtf",
    "publisher": "Lucaris SRL",
    "copyright": "© 2025 Lucaris. Toate drepturile rezervate.",
    "targets": ["dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Aplicație desktop pentru e-Factura ANAF",
    "longDescription": "Clarito — Aplicație desktop pentru gestionarea facturilor electronice prin sistemul ANAF SPV. Multi-companie, validare RO_CIUS, arhivare locală.",
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "12.0",
      "exceptionDomain": "webservicesp.anaf.ro",
      "signingIdentity": null,
      "providerShortName": "LUCARIS",
      "dmg": {
        "background": "resources/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 200 },
        "applicationFolderPosition": { "x": 480, "y": 200 }
      }
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "allowDowngrades": false,
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Romanian", "English"],
        "installMode": "currentUser",
        "headerImage": "resources/nsis-header.bmp",
        "sidebarImage": "resources/nsis-sidebar.bmp"
      },
      "wix": {
        "language": {
          "en-US": { "localePath": "wix/en-US.wxl" }
        }
      }
    },
    "fileAssociations": [
      {
        "name": "RO e-Factură XML",
        "description": "Fișier factură electronică RO",
        "ext": ["xml"],
        "mimeType": "application/xml"
      }
    ]
  }
}
